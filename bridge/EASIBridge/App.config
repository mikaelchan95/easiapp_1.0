<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Logging & Health -->
    <add key="LogDirectory" value="C:\ProgramData\EASI\Bridge\logs" />
    <add key="StatusDirectory" value="C:\ProgramData\EASI\Bridge\status" />
    <add key="ConfigDirectory" value="C:\ProgramData\EASI\Bridge\config" />
    <add key="HeartbeatIntervalSeconds" value="30" />

    <!-- AutoCount (future phases) - DO NOT fill in yet -->
    <add key="AutoCountInstallPath" value="C:\Program Files\AutoCount\Accounting 2.1" />
    <add key="AutoCountDbServer" value="__AUTOCOUNT_DB_SERVER__" />
    <add key="AutoCountDbName" value="__AUTOCOUNT_DB_NAME__" />

    <!-- Supabase (future phases) - DO NOT fill in yet -->
    <add key="SupabaseUrl" value="__SUPABASE_URL__" />
    <add key="SupabaseServiceKey" value="__SUPABASE_SERVICE_KEY__" />
  </appSettings>
</configuration>
