# Copy this file to .env and fill in your values.
# Expo loads .env automatically; EXPO_PUBLIC_* vars are exposed to the app.
# Restart the dev server after changing .env.

# =============================================================================
# Supabase (required for auth and data)
# =============================================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key
# Same values for Admin Web, EasiSales, EasiDriver (Vite loads from repo root)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key

# Service role key – optional; used for profile image upload and other admin ops.
# Do not expose in client; only used server-side or in trusted scripts.
# SUPABASE_SERVICE_KEY=

# Database password – for Supabase CLI (e.g. npx supabase db push). Load .env before running CLI or pass inline.
# SUPABASE_DB_PASSWORD=

# =============================================================================
# Google Maps (optional – for location picker and map features)
# =============================================================================
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# =============================================================================
# EAS / Expo (optional – for push notifications and EAS Build)
# =============================================================================
# EXPO_PUBLIC_EAS_PROJECT_ID=

# =============================================================================
# Stripe (optional – for payments)
# =============================================================================
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

# =============================================================================
# Tooling / CLI (optional – Supabase CLI, GitHub MCP, etc.)
# =============================================================================
# SUPABASE_ACCESS_TOKEN=
# GITHUB_TOKEN=
